{
  "name": "klaro",
  "version": "1.3.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mallwang/klaro"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pcm/shared build && concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "prepare": "husky",
    "release": "release-it --ci"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.0",
    "release-it": "^20.2.0",
    "typescript": "^5.5.0"
  }
}
